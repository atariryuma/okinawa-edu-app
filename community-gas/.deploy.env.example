# これをコピーして community-gas/.deploy.env を作る（.deploy.env は git管理外）。
# 値はスプレッドシート/Apps Script から取得して埋める。公開しないこと。
CLASP_USER=gmail
# Apps Script のスクリプトID（プロジェクトの設定 or .clasp.json）
SCRIPT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 投稿データを保存するスプレッドシートのID（URLの /d/ と /edit の間）
SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# アプリの DEFAULT_COMMUNITY_URL が指す /exec のデプロイID（clasp deployments で確認）
DEPLOYMENT_ID=AKfycbxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
